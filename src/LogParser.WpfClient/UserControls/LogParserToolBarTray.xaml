<UserControl x:Class="LogParser.WpfClient.UserControls.LogParserToolBarTray"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LogParser.WpfClient.UserControls.ToolBars"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LogParser.ElmishApp.Models;assembly=LogParser.ElmishApp"
             d:DesignHeight="100"
             d:DesignWidth="1800"
             mc:Ignorable="d"
             >
    <ToolBarTray VerticalAlignment="Top">
        <local:KibanaSearchToolBar DataContext="{Binding KibanaSearchModel}"
                                   Width="1400"
                                   Band="0"
                                   BandIndex="0"
                                   />
        <local:KibanaAccountToolBar DataContext="{Binding KibanaSearchModel}"
                                    Band="0"
                                    BandIndex="1"
                                    />
        <local:StandardToolBar DataContext="{Binding}"
                               Band="1"
                               />
        <local:FiltersToolBar DataContext="{Binding FiltersModel}"
                              Band="1"
                              />
    </ToolBarTray>
</UserControl>
