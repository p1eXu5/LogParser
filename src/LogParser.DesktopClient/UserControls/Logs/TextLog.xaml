<UserControl x:Class="LogParser.DesktopClient.UserControls.Logs.TextLog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:root="clr-namespace:LogParser.DesktopClient"
             d:DesignHeight="60"
             d:DesignWidth="800"
             mc:Ignorable="d"
             >
    <Border Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor,
                                                           AncestorType=Control},
                            Path=ActualWidth}"
            HorizontalAlignment="Stretch"
            >
        <!--  Margin="{Binding HierarchyLevel, Converter={StaticResource conv_HierarchyLevel}}"  -->
        <Behaviors:Interaction.Behaviors>
            <root:IgnoreMouseWheelBehavior />
        </Behaviors:Interaction.Behaviors>

        <Expander HorizontalAlignment="Stretch">
            <Expander.Header>
                <materialDesign:ColorZone>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" Tag="Log Header" />
                            <ColumnDefinition Width="Auto" Tag="Pinned Field" />
                            <ColumnDefinition Width="Auto" Tag="Copy Button" />
                            <ColumnDefinition Width="Auto" Tag="Exclamation Toggle Button" />
                        </Grid.ColumnDefinitions>

                        <!--  Log Header  -->
                        <Grid VerticalAlignment="Center"
                              TextElement.FontSize="16"
                              TextElement.Foreground="{StaticResource br_Foreground}"
                              ToolTipService.HasDropShadow="true"
                              ToolTipService.InitialShowDelay="3000"
                              ToolTipService.IsEnabled="true"
                              ToolTipService.ShowDuration="7000"
                              ToolTipService.ShowOnDisabled="true"
                              ToolTipService.VerticalOffset="10"
                              >
                            <Grid.ToolTip>
                                <ToolTip MaxWidth="800"
                                         Background="{StaticResource br_Background}"
                                         Foreground="{StaticResource br_Foreground}"
                                         >
                                    <TextBlock Text="{Binding Log}"
                                               TextWrapping="WrapWithOverflow"
                                               />
                                </ToolTip>
                            </Grid.ToolTip>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" Tag="Log Level" />
                                <ColumnDefinition Width="280" Tag="Timestamp" />
                                <ColumnDefinition Width="*" MinWidth="100" Tag="Message" />
                            </Grid.ColumnDefinitions>

                            <!--  Log Level  -->
                            <TextBlock Foreground="{Binding LogLevel, Converter={StaticResource conv_LogLevelToBrush}}">
                                <Run Text="" /><Run />
                            </TextBlock>

                            <!--  Timestamp  -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        >
                                <TextBlock Grid.Column="1"
                                           Text=""
                                           />
                            </StackPanel>
                            <!--  Message  -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Log}"
                                       TextAlignment="Left"
                                       TextTrimming="CharacterEllipsis"
                                       >
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding DecodeCommand}"
                                                  Header="Decode"
                                                  />
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </Grid>

                        <!--  Pinned Field  -->
                        <TextBlock DockPanel.Dock="Right"
                                   Grid.Column="1"
                                   Margin="10,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource br_ForegroundLight}"
                                   TextTrimming="CharacterEllipsis"
                                   >
                            <Run Text="" />
                        </TextBlock>

                        <!--  Copy Button  -->
                        <Button Grid.Column="2"
                                Command="{Binding CopyCommand}"
                                Style="{StaticResource MaterialDesignFlatLightButton}"
                                Margin="10,0"
                                IsHitTestVisible="True"
                                >
                            <materialDesign:PackIcon Kind="ContentCopy" />
                        </Button>

                        <!--  Exclamation Toggle Button  -->
                        <ToggleButton Grid.Column="3"
                                      ToolTip="MaterialDesignFlatToggleButton"
                                      Style="{StaticResource MaterialDesignFlatToggleButton}"
                                      >
                            <materialDesign:PackIcon Width="21"
                                                     Height="21"
                                                     Kind="ExclamationThick"
                                                     />
                        </ToggleButton>
                    </Grid>
                </materialDesign:ColorZone>
            </Expander.Header>
            <TextBox Margin="5"
                     BorderThickness="0"
                     IsReadOnly="True"
                     Text="{Binding Log}"
                     TextAlignment="Left"
                     TextWrapping="Wrap"
                     />
        </Expander>
    </Border>
</UserControl>
